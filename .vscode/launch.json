{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Server running on http://localhost:3000",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
